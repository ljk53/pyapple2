
10 INPUT SN
20 DIM D(SN),SS(SN),ES(SN)
30 FOR I=0 TO SN:D(I)=INT(RND(1)*SN*10):NEXT
40 N=0:S=0:E=SN
100 IF S<E THEN 130
110 IF NOT N THEN END
120 N=N-1:S=SS(N):E=ES(N):GOTO 100
130 PRINT "[";S;", ";E;"]"
140 P=D(INT((S+E)/2)):I=S-1:J=E+1
150 I=I+1:IF D(I)<P THEN 150
160 J=J-1:IF D(J)>P THEN 160
170 IF I<J THEN TEMP=D(I):D(I)=D(J):D(J)=TEMP:GOTO 150
180 FOR T=0 TO SN:PRINT D(T);" ";:NEXT:PRINT
190 SS(N)=J+1:ES(N)=E:E=J:N=N+1:GOTO 100

